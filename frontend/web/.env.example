# Copy to .env.local for Vite (optional overrides)
# API proxy target (default http://127.0.0.1:8000)
# VITE_PROXY_TARGET=http://127.0.0.1:8000
# WebSocket proxy target (default http://127.0.0.1:8009)
# VITE_WS_PROXY_TARGET=http://127.0.0.1:8009
# Direct WS URL (skip Vite proxy; e.g. ws://127.0.0.1:8009/api/v1/ws)
# VITE_WS_URL=
# OAuth buttons on login (default off — use email/password)
# VITE_OAUTH_ENABLED=true
# WebAuthn / passkey / biometric sign-in (default off on web)
# VITE_WEBAUTHN_ENABLED=false
# QR sign-in page and link device (default off on web)
# VITE_QR_LOGIN_ENABLED=false
# Standalone /verify-email page (default off; dev uses AUTO_VERIFY_EMAIL on server)
# VITE_EMAIL_VERIFICATION_UI_ENABLED=false
# Public API origin for OAuth redirects
# VITE_API_PUBLIC_URL=http://127.0.0.1:8000
# WebRTC ICE servers (JSON array or comma-separated STUN/TURN URLs)
# VITE_ICE_SERVERS=stun:stun.l.google.com:19302
