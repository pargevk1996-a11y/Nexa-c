{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nexa",
  "version": "0.1.0",
  "identifier": "app.nexa.desktop",
  "build": {
    "beforeDevCommand": "npm run dev --prefix ../../frontend/web",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build --prefix ../../frontend/web",
    "frontendDist": "../../frontend/web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Nexa",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:* ws://localhost:* https://*.nexa.app wss://*.nexa.app; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
