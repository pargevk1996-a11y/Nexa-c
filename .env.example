# =============================================================================
# Secure Chat — environment template (copy to .env, never commit .env)
# =============================================================================

APP_ENV=development
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# CORS (gateway)
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,https://localhost

# -----------------------------------------------------------------------------
# TLS / Nginx
# -----------------------------------------------------------------------------
TLS_CERT_PATH=./infrastructure/tls/dev/cert.pem
TLS_KEY_PATH=./infrastructure/tls/dev/key.pem

# -----------------------------------------------------------------------------
# JWT (auth-service issues; gateway validates)
# -----------------------------------------------------------------------------
JWT_ACCESS_SECRET=change-me-run-openssl-rand-hex-32
JWT_REFRESH_SECRET=change-me-run-openssl-rand-hex-32
JWT_ACCESS_TTL_SECONDS=600
JWT_REFRESH_TTL_SECONDS=604800
JWT_ALGORITHM=RS256
JWT_ACCESS_PRIVATE_KEY_FILE=./infrastructure/jwt/private.pem
JWT_ACCESS_PUBLIC_KEY_FILE=./infrastructure/jwt/public.pem
# HS256 fallback: set JWT_ALGORITHM=HS256 and JWT_ACCESS_SECRET only

# -----------------------------------------------------------------------------
# Cookies / CSRF (gateway)
# -----------------------------------------------------------------------------
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_SAMESITE=Strict
CSRF_ENABLED=true
CSRF_COOKIE_NAME=csrf_token
CSRF_HEADER_NAME=X-CSRF-Token

# -----------------------------------------------------------------------------
# Data at rest (server-side AES-GCM for message bodies; not E2EE)
# Generate: python -c "import base64,os;print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
# -----------------------------------------------------------------------------
DATA_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=securechat
POSTGRES_PASSWORD=change-me-postgres-password

AUTH_DATABASE_URL=postgresql+asyncpg://securechat:change-me-postgres-password@postgres:5432/auth_db
USER_DATABASE_URL=postgresql+asyncpg://securechat:change-me-postgres-password@postgres:5432/user_db
CONTACT_DATABASE_URL=postgresql+asyncpg://securechat:change-me-postgres-password@postgres:5432/contact_db
CHAT_DATABASE_URL=postgresql+asyncpg://securechat:change-me-postgres-password@postgres:5432/chat_db
MEDIA_DATABASE_URL=postgresql+asyncpg://securechat:change-me-postgres-password@postgres:5432/media_db
STORY_DATABASE_URL=postgresql+asyncpg://securechat:change-me-postgres-password@postgres:5432/story_db
EMOJI_DATABASE_URL=postgresql+asyncpg://securechat:change-me-postgres-password@postgres:5432/emoji_db
NOTIFICATION_DATABASE_URL=postgresql+asyncpg://securechat:change-me-postgres-password@postgres:5432/notification_db

# -----------------------------------------------------------------------------
# Realtime (ws-gateway, presence-service)
# -----------------------------------------------------------------------------
WS_GATEWAY_PORT=8009
PRESENCE_SERVICE_PORT=8010
WS_SERVICE_URL=http://127.0.0.1:8009
PRESENCE_SERVICE_URL=http://127.0.0.1:8010
# WS_NODE_ID=auto-generated if unset

# -----------------------------------------------------------------------------
# Calls (call-service — WebRTC signaling, STUN/TURN)
# -----------------------------------------------------------------------------
CALL_SERVICE_PORT=8011
CALL_SERVICE_URL=http://127.0.0.1:8011
STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
# Coturn (optional): comma-separated turn:host:port URLs + shared secret
TURN_URLS=
TURN_SECRET=
TURN_TTL_SECONDS=86400

# -----------------------------------------------------------------------------
# AI (ai-service — assistant, search, moderation, transcription)
# -----------------------------------------------------------------------------
AI_SERVICE_PORT=8012
AI_SERVICE_URL=http://127.0.0.1:8012
AI_PROVIDER=openai
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_CHAT_MODEL=gpt-4o-mini
AI_EMBED_MODEL=text-embedding-3-small
AI_WHISPER_MODEL=whisper-1
AI_REQUEST_TIMEOUT_SECONDS=30
AI_RATE_LIMIT_PER_MINUTE=30
AI_MODERATION_ENABLED=true
AI_MODERATION_BLOCK_THRESHOLD=0.75
AI_SPAM_BLOCK_THRESHOLD=0.8
INTERNAL_SERVICE_SECRET=change-me-internal-service-secret

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://:change-me-redis-password@redis:6379/0
REDIS_PASSWORD=change-me-redis-password

# -----------------------------------------------------------------------------
# Internal service URLs (gateway routing)
# -----------------------------------------------------------------------------
AUTH_SERVICE_URL=http://auth-service:8001
USER_SERVICE_URL=http://user-service:8002
CONTACT_SERVICE_URL=http://contact-service:8003
CHAT_SERVICE_URL=http://chat-service:8004
MEDIA_SERVICE_URL=http://media-service:8005

# Media pipeline (media-service)
MEDIA_STORAGE_ROOT=.dev/media-storage
MEDIA_CHUNK_SIZE=1048576
MEDIA_MAX_UPLOAD_BYTES=536870912
MEDIA_SIGNED_URL_TTL=300
MEDIA_SIGNING_SECRET=change-me-media-signing-secret
MEDIA_ENCRYPTION_KEY=
MEDIA_CDN_BASE_URL=http://127.0.0.1:8000/api/v1/media
STORY_SERVICE_URL=http://story-service:8006
EMOJI_SERVICE_URL=http://emoji-service:8007
NOTIFICATION_SERVICE_URL=http://notification-service:8008
CALL_SERVICE_URL=http://call-service:8011
AI_SERVICE_URL=http://ai-service:8012

# -----------------------------------------------------------------------------
# At-rest field encryption (chat / user services when persisting sensitive columns)
# Generate: python -c "import base64,os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
# -----------------------------------------------------------------------------
DATA_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# OAuth — Google & GitHub only (auth-service)
# Set OAUTH_ENABLED=false to use email/password login (OAuth code stays for later).
# Frontend: VITE_OAUTH_ENABLED=false (must match OAUTH_ENABLED).
# Redirect URIs (register at each provider):
#   http://127.0.0.1:8000/api/v1/auth/oauth/google/callback
#   http://127.0.0.1:8000/api/v1/auth/oauth/github/callback
# -----------------------------------------------------------------------------
OAUTH_ENABLED=true
FRONTEND_URL=http://127.0.0.1:5173
OAUTH_PUBLIC_BASE_URL=http://127.0.0.1:8000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# 2FA (auth-service)
# -----------------------------------------------------------------------------
TOTP_ENCRYPTION_KEY=change-me-32-byte-base64-secret
TWO_FA_CHALLENGE_TTL_SECONDS=300

# -----------------------------------------------------------------------------
# Email verification (auth-service) — opaque tokens, NOT JWT
# -----------------------------------------------------------------------------
EMAIL_VERIFICATION_TOKEN_TTL_SECONDS=86400
EMAIL_VERIFICATION_TOKEN_BYTES=32
EMAIL_VERIFICATION_BASE_URL=https://localhost/verify-email
EMAIL_RESEND_RATE_LIMIT_PER_EMAIL=1
EMAIL_RESEND_RATE_LIMIT_PER_IP=3

# -----------------------------------------------------------------------------
# Password reset (auth-service) — opaque tokens, NOT JWT
# -----------------------------------------------------------------------------
PASSWORD_RESET_TOKEN_TTL_SECONDS=3600
PASSWORD_RESET_TOKEN_BYTES=32
PASSWORD_RESET_BASE_URL=https://localhost/reset-password
PASSWORD_FORGOT_RATE_LIMIT_PER_EMAIL=1
PASSWORD_FORGOT_RATE_LIMIT_PER_IP=5
PASSWORD_RESET_RATE_LIMIT_PER_IP=10
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SPECIAL=true

# Login protection (auth-service) — always enforced (dev and production)
LOGIN_MAX_ATTEMPTS=3
LOGIN_FIRST_LOCKOUT_SECONDS=600
LOGIN_RETRY_LOCKOUT_SECONDS=300
LOGIN_MAX_STRIKES=3
# LOGIN_PROTECTION_USE_MEMORY=true  # tests only; production uses Redis

# -----------------------------------------------------------------------------
# SMTP (auth-service / dev Mailpit)
# -----------------------------------------------------------------------------
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_FROM=noreply@securechat.local
SMTP_USE_TLS=false

# -----------------------------------------------------------------------------
# Gateway
# -----------------------------------------------------------------------------
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000

# -----------------------------------------------------------------------------
# Local dev (make dev-up uses 127.0.0.1; Docker Compose uses service names)
# -----------------------------------------------------------------------------
AUTO_VERIFY_EMAIL=true
# OAUTH_ENABLED=false
