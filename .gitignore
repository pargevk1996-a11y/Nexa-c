# ──────────────────────────────────────────────────────────────────────────────
# Python
# ──────────────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
venv/
.venv/
env/
.env/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# ──────────────────────────────────────────────────────────────────────────────
# Environment & secrets — never commit real values
# ──────────────────────────────────────────────────────────────────────────────
.env
.env.local
.env.development
.env.production
.env.staging
.env.*.local
!.env.example
!.env.prod.example
!.env.staging.example
!.env.development.example
# Frontend env files (VITE_ vars may embed API base URLs)
frontend/web/.env
frontend/web/.env.local
frontend/web/.env.development
frontend/web/.env.production
frontend/web/.env.staging
!frontend/web/.env.example

# ──────────────────────────────────────────────────────────────────────────────
# Cryptographic material — private keys, certs, keystores
# ──────────────────────────────────────────────────────────────────────────────
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx
*.jks
*.keystore
# Keep the TLS generation helper script
!infrastructure/tls/dev/generate-dev-certs.sh
# JWT key directory (private + public generated at runtime)
infrastructure/jwt/

# ──────────────────────────────────────────────────────────────────────────────
# Node / frontend
# ──────────────────────────────────────────────────────────────────────────────
node_modules/
frontend/web/dist/
frontend/web/.vite/
frontend/web/coverage/
*.tsbuildinfo

# ──────────────────────────────────────────────────────────────────────────────
# IDE & AI assistant tools  ← SECURITY: may store API keys / tokens
# ──────────────────────────────────────────────────────────────────────────────
# Obsidian (plugins/copilot/data.json stores LLM API keys)
.obsidian/
# Cursor IDE
.cursor/
# Obsidian Copilot custom prompts (personal, not project code)
copilot/
# VS Code workspace settings (use .vscode/extensions.json if needed)
.vscode/
# JetBrains
.idea/
# Claude Code project settings (may include personal hooks / tokens)
.claude/

# ──────────────────────────────────────────────────────────────────────────────
# AI memory & scratch files
# ──────────────────────────────────────────────────────────────────────────────
ClaudeMemory.md
Untitled.base
*.base

# ──────────────────────────────────────────────────────────────────────────────
# OS artefacts
# ──────────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo

# ──────────────────────────────────────────────────────────────────────────────
# Docker / process runtime
# ──────────────────────────────────────────────────────────────────────────────
*.pid
*.log

# ──────────────────────────────────────────────────────────────────────────────
# Local dev runtime data (PostgreSQL, Redis, service logs & pids)
# ──────────────────────────────────────────────────────────────────────────────
.dev/
**/.dev/

# ──────────────────────────────────────────────────────────────────────────────
# Test artefacts
# ──────────────────────────────────────────────────────────────────────────────
test-results/

# ──────────────────────────────────────────────────────────────────────────────
# Local dev tools (PostgreSQL, Redis, Node binaries — not for version control)
# ──────────────────────────────────────────────────────────────────────────────
.tools/

# ──────────────────────────────────────────────────────────────────────────────
# Terraform / IaC secrets
# ──────────────────────────────────────────────────────────────────────────────
*.tfstate
*.tfstate.backup
*.tfvars
.terraform/
.terraform.lock.hcl
