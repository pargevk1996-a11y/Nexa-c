# Staging environment — copy to .env.staging (never commit secrets)
APP_ENV=staging
LOG_LEVEL=info

CORS_ORIGINS=https://staging.example.com
TLS_CERT_PATH=./infrastructure/tls/staging/cert.pem
TLS_KEY_PATH=./infrastructure/tls/staging/key.pem

JWT_ALGORITHM=RS256
JWT_ACCESS_PRIVATE_KEY_FILE=./infrastructure/jwt/staging/private.pem
JWT_ACCESS_PUBLIC_KEY_FILE=./infrastructure/jwt/staging/public.pem
COOKIE_DOMAIN=staging.example.com
COOKIE_SECURE=true

POSTGRES_HOST=postgres
POSTGRES_USER=securechat
POSTGRES_PASSWORD=CHANGE_ME_staging_postgres
REDIS_PASSWORD=CHANGE_ME_staging_redis

AUTH_DATABASE_URL=postgresql+asyncpg://securechat:CHANGE_ME_staging_postgres@postgres:5432/auth_db
USER_DATABASE_URL=postgresql+asyncpg://securechat:CHANGE_ME_staging_postgres@postgres:5432/user_db
CONTACT_DATABASE_URL=postgresql+asyncpg://securechat:CHANGE_ME_staging_postgres@postgres:5432/contact_db
CHAT_DATABASE_URL=postgresql+asyncpg://securechat:CHANGE_ME_staging_postgres@postgres:5432/chat_db
MEDIA_DATABASE_URL=postgresql+asyncpg://securechat:CHANGE_ME_staging_postgres@postgres:5432/media_db
STORY_DATABASE_URL=postgresql+asyncpg://securechat:CHANGE_ME_staging_postgres@postgres:5432/story_db
EMOJI_DATABASE_URL=postgresql+asyncpg://securechat:CHANGE_ME_staging_postgres@postgres:5432/emoji_db
NOTIFICATION_DATABASE_URL=postgresql+asyncpg://securechat:CHANGE_ME_staging_postgres@postgres:5432/notification_db

DATA_ENCRYPTION_KEY=CHANGE_ME_base64_32_bytes
INTERNAL_SERVICE_SECRET=CHANGE_ME_internal
MEDIA_SIGNING_SECRET=CHANGE_ME_media_signing

OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces
PROMETHEUS_METRICS_ENABLED=true

OAUTH_ENABLED=true
FRONTEND_URL=https://staging.example.com
OAUTH_PUBLIC_BASE_URL=https://staging.example.com
