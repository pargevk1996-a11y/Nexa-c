# Production environment — copy to .env.prod (use secrets manager in real deployments)
APP_ENV=production
LOG_LEVEL=warning

CORS_ORIGINS=https://app.example.com
TLS_CERT_PATH=/etc/nginx/certs/fullchain.pem
TLS_KEY_PATH=/etc/nginx/certs/privkey.pem

JWT_ALGORITHM=RS256
JWT_ACCESS_PRIVATE_KEY_FILE=/run/secrets/jwt_private.pem
JWT_ACCESS_PUBLIC_KEY_FILE=/run/secrets/jwt_public.pem
COOKIE_DOMAIN=.example.com
COOKIE_SECURE=true
CSRF_ENABLED=true

# Managed Postgres / Redis (replace hostnames)
POSTGRES_HOST=prod-postgres.internal
POSTGRES_PORT=5432
POSTGRES_USER=securechat
POSTGRES_PASSWORD=FROM_VAULT
REDIS_URL=rediss://:FROM_VAULT@prod-redis.internal:6379/0

AUTH_DATABASE_URL=postgresql+asyncpg://securechat:FROM_VAULT@prod-postgres.internal:5432/auth_db
USER_DATABASE_URL=postgresql+asyncpg://securechat:FROM_VAULT@prod-postgres.internal:5432/user_db
CONTACT_DATABASE_URL=postgresql+asyncpg://securechat:FROM_VAULT@prod-postgres.internal:5432/contact_db
CHAT_DATABASE_URL=postgresql+asyncpg://securechat:FROM_VAULT@prod-postgres.internal:5432/chat_db
MEDIA_DATABASE_URL=postgresql+asyncpg://securechat:FROM_VAULT@prod-postgres.internal:5432/media_db
STORY_DATABASE_URL=postgresql+asyncpg://securechat:FROM_VAULT@prod-postgres.internal:5432/story_db
EMOJI_DATABASE_URL=postgresql+asyncpg://securechat:FROM_VAULT@prod-postgres.internal:5432/emoji_db
NOTIFICATION_DATABASE_URL=postgresql+asyncpg://securechat:FROM_VAULT@prod-postgres.internal:5432/notification_db

DATA_ENCRYPTION_KEY=FROM_VAULT
INTERNAL_SERVICE_SECRET=FROM_VAULT
MEDIA_SIGNING_SECRET=FROM_VAULT
MEDIA_CDN_BASE_URL=https://cdn.example.com/api/v1/media

AI_API_KEY=FROM_VAULT
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USE_TLS=true

OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=https://otel-collector.internal:4318/v1/traces
PROMETHEUS_METRICS_ENABLED=true

BACKUP_RETENTION_DAYS=30
